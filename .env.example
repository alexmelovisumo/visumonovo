# ============================================================
# VISUMO — Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local com valores reais!
# ============================================================

# Supabase — obtenha em: https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<sua-anon-key>

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# PagSeguro/PagBank — apenas para Supabase Edge Functions (NÃO usar prefixo VITE_)
# Configure também em: Supabase Dashboard → Edge Functions → Secrets
PAGSEGURO_TOKEN=<seu-token-pagseguro>
PAGSEGURO_ENVIRONMENT=production
PAGSEGURO_BASE_URL=https://api.pagseguro.com
